{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "importHelpers": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["dom", "esnext"],
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
